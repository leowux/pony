{
  "name": "pony-cli",
  "version": "0.0.1",
  "description": "Lightweight task management for Claude Code sessions",
  "keywords": [
    "claude-code",
    "plugin",
    "productivity",
    "task-management"
  ],
  "license": "MIT",
  "author": {
    "name": "wuwenbang"
  },
  "bin": {
    "pony": "dist/cli/index.mjs"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "check": "vp check",
    "clean": "rm -rf dist/",
    "typecheck": "tsc --noEmit",
    "release": "release-it",
    "release:dry": "release-it --dry-run"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/node": "^20.0.0",
    "release-it": "^19.2.4",
    "typescript": "^5.3.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.15",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.15"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
